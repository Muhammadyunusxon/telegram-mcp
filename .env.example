# === MAJBURIY ===
# my.telegram.org -> API development tools dan oling
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Session fayl nomi (o'zgartirish shart emas)
TELEGRAM_SESSION=telegram_mcp

# === IXTIYORIY: XAVFSIZLIK ===
# Faqat o'qish rejimi: "1" bo'lsa barcha yozish/o'zgartirish amallari o'chadi
# TELEGRAM_READONLY=1

# Allowlist: xabar faqat shu chatlarga yuboriladi (vergul bilan)
# TELEGRAM_ALLOWED_PEERS=@mening_kanalim,123456789,me

# Avtomatik kutiladigan maksimal FloodWait (soniya). Default: 60
# TELEGRAM_MAX_FLOODWAIT=60
